class Solution {
    public int maxFrequencyElements(int[] nums) {

        int[] freq = new int[101];

        int max = 0;
        int count = 0;

        for(int x : nums)
        {
            freq[x]++;

            if(freq[x] > max)
            {
                max = freq[x];
                count = freq[x];
            }
            else if(freq[x] == max)
            {
                count += freq[x];
            }
        }

        return count;
    }

}